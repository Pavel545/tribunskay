---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/hero.astro';
import About from '../components/about.astro';
import ACell from '../components/aCell.astro';
import Evg from '../components/evgenia.astro';
import Activities from '../components/activities.astro';
import FinAudit from '../components/finAudit.astro';
import TrainingMain from '../components/TrainingMain.astro';
import Slider from '../components/ui/Slider.astro';



const images: string[] = [
  '/img/slider/1.jpg',
  '/img/slider/2.jpg',
  '/img/slider/3.jpg',
];
---

<Layout>
	<Hero/>
	<About/>
	<ACell/>

	<Evg/>
	<Activities/>
	<Slider images={images}/>
	<FinAudit />
	<TrainingMain/>
</Layout>
