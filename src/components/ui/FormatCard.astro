---
export interface Props {
    title: string;
    color: string;
    who: string;
    cost: string;
    bg?: string;
    item: string[];
    itemDop: string[];
    isHighlighted?: boolean;
}

const {
    title,
    color = "#ffba08",
    who,
    cost,
    item,
    itemDop,
    bg = "#fff",
     isHighlighted
} = Astro.props;
---

<div style={`--color:${color}; background:${bg}`} class="FormatCard">
    <span class="who">
        {who}
    </span>
    <h3 class="title">
        {title}
    </h3>

    <div class="FormatCardList">
        <h4 class="FormatCardH4">Что входит</h4>
        <ul class="list">
            {item.map((e, i) => <li class="listItem t20">{e}</li>)}
        </ul>

        <h4 class="FormatCardH4">Доп. услуга</h4>
        <ul class="list">
            {itemDop.map((e, i) => <li class="listItem t20">{e}</li>)}
        </ul>
    </div>

    <div class="cost">
        <p class="FormatCardH4">Стоимость</p>
        <span class="costText" style="color: var(--color);">
            {cost}
        </span>
    </div>
    <button
    class="butt cardBut"
    style={`--bg:${color}; --col:var(--belyy); --colH: var(--zheltyy); --bgH: var(--belyy);`}
    data-popup
data-popup-title={`формат обучения ${title}`}
    >
    Выбрать
</button>
</div>



<style>

    .FormatCardList{
        display: flex;
        flex-direction: column;
        gap: 30px;
        margin-top: 30px;
        margin-bottom: 95px;
    }
    .costText {
        font-weight: 700;
        font-style: Bold;
        font-size: 50px;
        line-height: 90%;
        letter-spacing: 0%;
        text-transform: uppercase;
    }
    .cost {
        margin-bottom: 30px;
    }

    .FormatCardH4 {
        font-weight: 400;
        font-size: 20px;
        line-height: 130%;
        letter-spacing: 0%;
        color: #787878;
        margin-bottom: 20px;
    }
    .FormatCard {
        background: #202020;

        display: flex;
        flex-direction: column;

        padding: 40px 30px;

        min-height: 474px;
        transition: 300ms all;
        border: 4px solid transparent;

    }

    .FormatCard:hover{
        border: 4px solid var(--color);
    }

    .who {
        font-family: var(--font-family);
        font-weight: 400;
        font-size: 16px;
        line-height: 100%;
        color: #9e9e9e;
        padding-bottom: 20px;
        padding-top: 10px;
    }

    .title {
        font-family: var(--second-family);
        font-weight: 700;
        font-size: 50px;
        line-height: 90%;
        text-transform: uppercase;
        color: var(--color);
    }
    .list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .listItem {
        list-style: disc;
        margin-left: 20px;
    }

    .listItem::marker {
        color: var(--color);
    }

    .cardBut {
        margin-top: auto;
        font-size: 18px;
    }

    /* ===== АДАПТИВ ===== */
    
    /* Планшеты (768px - 1024px) */
    @media (max-width: 1024px) {
        .FormatCard {
            padding: 30px 25px;
            min-height: auto;
        }
        
        .title {
            font-size: 40px;
        }
        
        .costText {
            font-size: 42px;
        }
        
        .FormatCardList {
            margin-bottom: 60px;
            gap: 25px;
        }
        
        .FormatCardH4 {
            font-size: 18px;
            margin-bottom: 15px;
        }
    }
    
    /* Мобильные устройства (до 768px) */
    @media (max-width: 768px) {
        .FormatCard {
            padding: 25px 20px;
        }
        
        .who {
            font-size: 14px;
            padding-bottom: 15px;
        }
        
        .title {
            font-size: 32px;
        }
        
        .costText {
            font-size: 36px;
        }
        
        .FormatCardList {
            margin-bottom: 40px;
            margin-top: 20px;
            gap: 20px;
        }
        
        .FormatCardH4 {
            font-size: 16px;
            margin-bottom: 12px;
        }
        
        .list {
            gap: 12px;
        }
        
        .listItem {
            font-size: 14px;
            margin-left: 18px;
        }
        
        .cost {
            margin-bottom: 20px;
        }
        
        .cardBut {
            font-size: 16px;
            padding: 12px 20px;.video-section
        }
    }
    
    /* Маленькие мобильные (до 480px) */
    @media (max-width: 480px) {
        .FormatCard {
            padding: 20px 15px;
        }
        
        .title {
            font-size: 24px;
        }
        
        .costText {
            font-size: 30px;
        }
        
        .FormatCardList {
            gap: 15px;
        }
        
        .listItem {
            font-size: 13px;
            margin-left: 16px;
        }
    }
</style>