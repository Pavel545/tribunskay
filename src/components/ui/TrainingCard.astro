---
export interface Props {
    title: string;
    color: string;
    who: string;
    slug: string;
    bg?: string;
    item: string[];
}

const {
    title,
    color = "#ffba08",
    who,
    slug,
    item,
    bg = "#202020",
} = Astro.props;
---

<div style={`--color:${color}; background:${bg}`} class="TrainingCard">
    <h3 class="title">
        {title}
    </h3>
    <span class="who">
        {who}
    </span>

    <ul class="list">
        {item.map((e, i) => <li class="listItem t20">{e}</li>)}
    </ul>

    <a
        href={`/pakety/${slug}`}
        class="butt cardBut"
        style={`--bg:${color}; --col:var(--belyy); --colH: var(--zheltyy); --bgH: var(--belyy);`}
    >
        Записаться на обучение
    </a>
</div>

<style>
    .TrainingCard {
        background: #202020;

        display: flex;
        flex-direction: column;

        padding: 40px 30px;

        min-height: 474px;
    }

    .who {
        font-family: var(--font-family);
        font-weight: 400;
        font-size: 16px;
        line-height: 100%;
        color: #9e9e9e;
        padding-bottom: 50px;
        padding-top: 10px;
    }

    .title {
        font-family: var(--second-family);
        font-weight: 700;
        font-size: max(12px, 2.2rem);
        line-height: 1;
        text-transform: uppercase;
        color: var(--color);
    }

@media (max-width: 780px) {
        .TrainingCard {


        min-height: 374px;
    }

    .title {
     
        font-size: max(12px, 1.5rem);
      
    }
}
    .list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .listItem {
        list-style: disc;
        margin-left: 20px;
    }

    .listItem::marker {
        color: var(--color);
    }

    .cardBut {
        margin-top: auto;
        font-size: 18px;
    }
</style>
