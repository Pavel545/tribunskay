---
export interface Props {
    title: string;
    color: string;
    who: string;
    bg?: string;
    item: string[];
}

const { title, color = "#ffba08", who, item, bg = "#202020" } = Astro.props;
---

<div style={`--color:${color}; background:${bg}`} class="TrainingCard">
    <h3 class="title">
        {title}
    </h3>
    <span class="who">
        {who}
    </span>

    <ul class="list">
        {item.map((e, i) => <li class="listItem t20">{e}</li>)}
    </ul>

    <button
        class="butt cardBut"
        style={`--bg:${color}; --col:var(--belyy); --colH: var(--zheltyy); --bgH: var(--belyy);`}
    >
        Записаться на обучение
    </button>
</div>

<style>
    .TrainingCard {
        background: #202020;

        display: flex;
        flex-direction: column;

        padding: 40px 30px;

        min-height: 474px;
    }

    .who {
        font-family: var(--font-family);
        font-weight: 400;
        font-size: 16px;
        line-height: 100%;
        color: #9e9e9e;
        padding-bottom: 50px;
        padding-top: 10px;
    }

    .title {
        font-family: var(--second-family);
        font-weight: 700;
        font-size: 50px;
        line-height: 90%;
        text-transform: uppercase;
        color: var(--color);
    }
    .list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .listItem {
        list-style: disc;
        margin-left: 20px;
    }

    .listItem::marker {
        color: var(--color);
    }

    .cardBut {
        margin-top: auto;
        font-size: 18px;
    }
</style>
