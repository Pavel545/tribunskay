---
// components/PopupForm.astro
export interface Props {
    id?: string;
    defaultTitle?: string;
}

const { id = "popup-form", defaultTitle = "Бесплатный аудит" } = Astro.props;
---

<div
    id={id}
    class="popup-overlay"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
>
    <div class="popup-container">
        <button class="popup-close" aria-label="Закрыть окно">
            <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <path d="M18 6L6 18M6 6l12 12"></path>
            </svg>
        </button>

        <div class="form-card">
            <h2 class="title" id="popup-title">{defaultTitle}</h2>

            <form id="popupOrderForm" class="form">
                <input type="hidden" name="form_title" value={defaultTitle} />

                <div class="input-wrapper">
                    <input type="text" name="name" placeholder="Ваше имя" />
                    <span class="error-message"></span>
                </div>

                <div class="input-wrapper">
                    <input type="email" name="email" placeholder="E-mail" />
                    <span class="error-message"></span>
                </div>

                <div class="input-wrapper">
                    <input
                        type="tel"
                        name="phone"
                        placeholder="+7 (___) ___-__-__"
                        required
                    />
                    <span class="error-message"></span>
                </div>

                <textarea name="service" placeholder="Комментарий к обращению"
                ></textarea>

                <button type="submit">ОТПРАВИТЬ</button>

                <label class="checkbox">
                    <input type="checkbox" name="privacy_policy" />
                    <span>
                        Нажимая кнопку "Отправить", Вы подтверждаете что
                        ознакомились с
                        <a href="#">Правилами обработки персональных данных</a>
                    </span>
                </label>
                <span class="error-message privacy-error"></span>
            </form>
        </div>
    </div>
</div>

<style>
    /* ===== Основные переменные (наследуются из :root) ===== */
    /* 
    :root {
        --belyy: #fff;
        --svetlyy: #f8f8f8;
        --svetlo-seryy: #c8c8c8;
        --seryy: #787878;
        --svetlo-siniy: #e4e7ee;
        --zheltyy: #ffbf00;
        --oranzhevyy: #e85d04;
        --temnyy: #282631;
        --chernyy: #0a0a0a;
    }
    */

    .popup-overlay {
        position: fixed;
        inset: 0;
        background: rgba(10, 10, 10, 0.7);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        visibility: hidden;
        transition:
            opacity 0.3s ease,
            visibility 0.3s ease;
        padding: 16px;
    }

    .popup-overlay.active {
        opacity: 1;
        visibility: visible;
    }

    .popup-container {
        position: relative;
        width: 100%;
        max-width: 520px;
        animation: slideUp 0.3s ease;
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .popup-close {
        position: absolute;
        top: -40px;
        right: 0;
        background: none;
        border: none;
        color: var(--belyy);
        cursor: pointer;
        padding: 8px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
            opacity 0.2s,
            transform 0.2s;
    }

    .popup-close:hover {
        opacity: 0.7;
        transform: scale(1.05);
    }

    .form-card {
        background: var(--belyy);
        border-radius: 20px;
        padding: 32px;
        box-shadow: 0 20px 40px rgba(10, 10, 10, 0.2);
    }

    .title {
        font-size: 36px;
        font-weight: 700;
        margin-bottom: 24px;
        color: var(--temnyy);
    }

    .title .yellow {
        color: var(--zheltyy);
    }

    .form {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .input-wrapper {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    input,
    textarea {
        padding: 16px 18px;
        border-radius: 12px;
        border: 1.5px solid var(--svetlo-seryy);
        background: var(--svetlyy);
        font-size: 16px;
        font-family: inherit;
        transition: all 0.2s ease;
        color: var(--temnyy);
    }

    input::placeholder,
    textarea::placeholder {
        color: var(--seryy);
        opacity: 0.7;
    }

    input:focus,
    textarea:focus {
        outline: none;
        border-color: var(--zheltyy);
        background: var(--belyy);
        box-shadow: 0 0 0 3px rgba(255, 191, 0, 0.1);
    }

    input.error,
    textarea.error {
        border-color: var(--oranzhevyy);
        background: rgba(232, 93, 4, 0.05);
    }

    .error-message {
        font-size: 12px;
        color: var(--oranzhevyy);
        min-height: 16px;
        padding-left: 4px;
    }

    .privacy-error {
        margin-top: -8px;
    }

    textarea {
        min-height: 100px;
        resize: vertical;
        font-family: inherit;
    }

    button[type="submit"] {
        background: var(--zheltyy);
        border: none;
        padding: 16px 24px;
        font-weight: 700;
        font-size: 16px;
        letter-spacing: 0.5px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        color: var(--temnyy);
        margin-top: 8px;
    }

    button[type="submit"]:hover {
        opacity: 0.9;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(255, 191, 0, 0.3);
    }

    button[type="submit"]:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    .checkbox {
        display: flex;
        gap: 12px;
        font-size: 13px;
        color: var(--seryy);
        align-items: flex-start;
    }

    .checkbox input {
        width: 18px;
        height: 18px;
        min-width: 18px;
        margin-top: 2px;
        accent-color: var(--zheltyy);
    }

    .checkbox a {
        color: var(--zheltyy);
        text-decoration: none;
        transition: opacity 0.2s;
    }

    .checkbox a:hover {
        opacity: 0.7;
        text-decoration: underline;
    }

    .checkbox.error-text {
        color: var(--oranzhevyy);
    }

    /* Адаптив */
    @media (max-width: 480px) {
        .title {
            font-size: 28px;
            margin-bottom: 20px;
        }
        .form-card {
            padding: 24px;
        }
        .popup-close {
            top: -36px;
        }
        input,
        textarea {
            padding: 14px 16px;
        }
        button[type="submit"] {
            padding: 14px 20px;
        }
    }

    @media (max-width: 380px) {
        .form-card {
            padding: 20px;
        }

        .title {
            font-size: 24px;
            margin-bottom: 16px;
        }

        input,
        textarea {
            padding: 12px 14px;
            font-size: 14px;
        }

        button[type="submit"] {
            padding: 12px 16px;
        }

        .checkbox {
            font-size: 12px;
            gap: 8px;
        }

        .checkbox input {
            width: 20px;
            height: 20px;
            min-width: 20px;
        }

        .popup-close svg {
            width: 28px;
            height: 28px;
        }
    }
</style>

<script>
   // Замените весь класс PopupForm на этот (только измененные части)

class PopupForm {
    private overlay: HTMLElement;
    private form: HTMLFormElement | null;
    private titleElement: HTMLElement | null;
    private formTitleInput: HTMLInputElement | null;
    private closeBtn: HTMLElement | null;
    private submitBtn: HTMLButtonElement | null;
    private nameInput: HTMLInputElement | null;
    private phoneInput: HTMLInputElement | null;
    private emailInput: HTMLInputElement | null;
    private serviceInput: HTMLTextAreaElement | null;
    private privacyInput: HTMLInputElement | null;
    private privacyError: HTMLElement | null;
    private endpoint: string;
    private formContainer: HTMLElement | null;
    private scrollPosition: number = 0; // Сохраняем позицию прокрутки

    constructor(popupElement: HTMLElement) {
        this.overlay = popupElement;
        this.form = popupElement.querySelector("#popupOrderForm");
        this.formContainer = this.form?.closest(".form-card") || null;
        this.titleElement = popupElement.querySelector("#popup-title");
        this.formTitleInput =
            this.form?.querySelector('input[name="form_title"]') || null;
        this.closeBtn = popupElement.querySelector(".popup-close");
        this.privacyError =
            this.form?.querySelector(".privacy-error") || null;

        this.submitBtn =
            this.form?.querySelector('button[type="submit"]') || null;
        this.nameInput =
            this.form?.querySelector('input[name="name"]') || null;
        this.phoneInput =
            this.form?.querySelector('input[name="phone"]') || null;
        this.emailInput =
            this.form?.querySelector('input[name="email"]') || null;
        this.serviceInput =
            this.form?.querySelector('textarea[name="service"]') || null;
        this.privacyInput =
            this.form?.querySelector('input[name="privacy_policy"]') ||
            null;

        this.endpoint =
            "/api/popup-form";

        this.init();
    }

    private init(): void {
        this.bindEvents();
        this.setupGlobalListeners();
        this.setupMask();
    }

    private bindEvents(): void {
        this.closeBtn?.addEventListener("click", () => this.close());

        this.overlay.addEventListener("click", (e: MouseEvent) => {
            if (e.target === this.overlay) {
                this.close();
            }
        });

        document.addEventListener("keydown", (e: KeyboardEvent) => {
            if (e.key === "Escape" && this.isOpen()) {
                this.close();
            }
        });

        const inputs = [
            this.nameInput,
            this.phoneInput,
            this.emailInput,
        ].filter(Boolean) as HTMLInputElement[];
        
        inputs.forEach((input) => {
            input.addEventListener("input", () => this.clearError(input));
            input.addEventListener("blur", () => this.validateField(input));
        });

        if (this.privacyInput) {
            this.privacyInput.addEventListener("change", () => {
                this.validatePrivacyCheckbox();
            });
        }

        this.form?.addEventListener("submit", (e: Event) =>
            this.handleSubmit(e),
        );
    }

    private setupGlobalListeners(): void {
        document.addEventListener("open-popup", (e: Event) => {
            const customEvent = e as CustomEvent;
            const { title, service } = customEvent.detail || {};
            this.open(title, service);
        });

        document.addEventListener("click", (e: MouseEvent) => {
            const trigger = (e.target as HTMLElement).closest(
                "[data-popup]",
            ) as HTMLElement;
            if (!trigger) return;

            const title =
                trigger.dataset.popupTitle ||
                trigger.getAttribute("title") ||
                "";
            const service = trigger.dataset.popupService || "";

            this.open(title, service);
        });
    }

    private setupMask(): void {
        if (!this.phoneInput) return;

        this.phoneInput.addEventListener("input", (e: Event) => {
            const input = e.target as HTMLInputElement;
            let value = input.value.replace(/\D/g, "");

            if (!value) {
                input.value = "";
                return;
            }

            if (value.length > 11) {
                value = value.slice(0, 11);
            }

            let formatted = "+7";
            if (value.length > 1) formatted += " (" + value.slice(1, 4);
            if (value.length >= 4) formatted += ") " + value.slice(4, 7);
            if (value.length >= 7) formatted += "-" + value.slice(7, 9);
            if (value.length >= 9) formatted += "-" + value.slice(9, 11);

            input.value = formatted;
        });

        this.phoneInput.addEventListener("focus", () => {
            if (this.phoneInput && !this.phoneInput.value) {
                this.phoneInput.value = "+7 (";
            }
        });
    }

    private getErrorMessage(fieldName: string, type: string): string {
        const messages: Record<string, Record<string, string>> = {
            name: {
                required: "Введите ваше имя",
                minLength: "Имя должно содержать минимум 2 символа",
                invalid: "Имя должно содержать только буквы",
            },
            phone: {
                required: "Введите номер телефона",
                incomplete: "Введите номер телефона полностью",
            },
            email: {
                invalid: "Введите корректный email",
            },
            privacy: {
                required: "Необходимо согласие на обработку данных",
            },
        };

        return messages[fieldName]?.[type] || "Поле заполнено некорректно";
    }

    private validateName(value: string): {
        valid: boolean;
        error?: string;
    } {
        if (!value.trim()) {
            return {
                valid: false,
                error: this.getErrorMessage("name", "required"),
            };
        }
        if (value.trim().length < 2) {
            return {
                valid: false,
                error: this.getErrorMessage("name", "minLength"),
            };
        }
        if (!/^[a-zA-Zа-яА-ЯёЁ\s\-]+$/.test(value.trim())) {
            return {
                valid: false,
                error: this.getErrorMessage("name", "invalid"),
            };
        }
        return { valid: true };
    }

    private validatePhone(value: string): {
        valid: boolean;
        error?: string;
    } {
        if (!value.trim()) {
            return {
                valid: false,
                error: this.getErrorMessage("phone", "required"),
            };
        }
        const digits = value.replace(/\D/g, "");
        if (digits.length < 11) {
            return {
                valid: false,
                error: this.getErrorMessage("phone", "incomplete"),
            };
        }
        return { valid: true };
    }

    private validateEmail(value: string): {
        valid: boolean;
        error?: string;
    } {
        if (!value) return { valid: true };

        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value.trim())) {
            return {
                valid: false,
                error: this.getErrorMessage("email", "invalid"),
            };
        }
        return { valid: true };
    }

    private showFieldError(input: HTMLElement, message: string): void {
        const wrapper = input.closest(".input-wrapper");
        const errorSpan = wrapper?.querySelector(".error-message");

        input.classList.add("error");
        if (errorSpan) {
            errorSpan.textContent = message;
        }
    }

    private clearError(input: HTMLElement): void {
        const wrapper = input.closest(".input-wrapper");
        const errorSpan = wrapper?.querySelector(".error-message");

        input.classList.remove("error");
        if (errorSpan) {
            errorSpan.textContent = "";
        }
    }

    private validatePrivacyCheckbox(): boolean {
        const isChecked = this.privacyInput?.checked || false;
        const checkboxLabel = this.privacyInput?.closest(".checkbox");

        if (!isChecked && this.privacyError) {
            this.privacyError.textContent = this.getErrorMessage(
                "privacy",
                "required",
            );
            checkboxLabel?.classList.add("error-text");
            return false;
        } else {
            if (this.privacyError) {
                this.privacyError.textContent = "";
            }
            checkboxLabel?.classList.remove("error-text");
            return true;
        }
    }

    private validateField(input: HTMLElement): boolean {
        if (!input) return true;

        let result: { valid: boolean; error?: string } = { valid: true };

        if (input === this.nameInput) {
            result = this.validateName((input as HTMLInputElement).value);
        } else if (input === this.phoneInput) {
            result = this.validatePhone((input as HTMLInputElement).value);
        } else if (input === this.emailInput) {
            result = this.validateEmail((input as HTMLInputElement).value);
        } else if (input === this.privacyInput) {
            return this.validatePrivacyCheckbox();
        }

        if (!result.valid && result.error) {
            this.showFieldError(input, result.error);
            return false;
        } else {
            this.clearError(input);
            return true;
        }
    }

    private validateForm(): boolean {
        const nameValid = this.nameInput
            ? this.validateField(this.nameInput)
            : true;
        const phoneValid = this.phoneInput
            ? this.validateField(this.phoneInput)
            : true;
        const emailValid = this.emailInput
            ? this.validateField(this.emailInput)
            : true;
        const privacyValid = this.validatePrivacyCheckbox();

        return [nameValid, phoneValid, emailValid, privacyValid].every(
            Boolean,
        );
    }

    private showSuccessMessage(): void {
        if (!this.submitBtn) return;

        const originalText = this.submitBtn.textContent;
        this.submitBtn.textContent = "✓ Заявка принята!";
        this.submitBtn.style.backgroundColor = "#10b981";
        this.submitBtn.style.color = "white";

        setTimeout(() => {
            if (this.submitBtn) {
                this.submitBtn.textContent = originalText;
                this.submitBtn.style.backgroundColor = "";
                this.submitBtn.style.color = "";
            }
        }, 1500);
    }

    private async quickRefreshForm(): Promise<void> {
        if (!this.formContainer) return;

        // Добавляем анимацию обновления
        this.formContainer.style.opacity = "0.5";
        this.formContainer.style.transform = "scale(0.98)";
        this.formContainer.style.transition = "all 0.15s ease";

        await new Promise((resolve) => setTimeout(resolve, 150));

        // Очищаем поля формы
        if (this.nameInput) this.nameInput.value = "";
        if (this.emailInput) this.emailInput.value = "";
        if (this.phoneInput) this.phoneInput.value = "";
        if (this.serviceInput) this.serviceInput.value = "";
        if (this.privacyInput) this.privacyInput.checked = false;

        // Очищаем ошибки
        const allErrors =
            this.formContainer.querySelectorAll(".error-message");
        allErrors.forEach((error) => (error.textContent = ""));
        const allErrorInputs =
            this.formContainer.querySelectorAll(".error");
        allErrorInputs.forEach((input) => input.classList.remove("error"));

        // Возвращаем анимацию
        this.formContainer.style.opacity = "1";
        this.formContainer.style.transform = "scale(1)";

        setTimeout(() => {
            if (this.formContainer) {
                this.formContainer.style.transition = "";
            }
        }, 200);
    }

    private async handleSuccessAndClose(): Promise<void> {
        this.showSuccessMessage();
        await new Promise((resolve) => setTimeout(resolve, 1200));
        this.close();
        setTimeout(() => {
            this.quickRefreshForm();
        }, 300);
    }

    private async handleSubmit(event: Event): Promise<void> {
        event.preventDefault();

        if (!this.validateForm()) return;

        if (this.submitBtn) {
            this.submitBtn.disabled = true;
        }

        try {
            const formData = new FormData(this.form!);
            const data: Record<string, any> = {};

            formData.forEach((value, key) => {
                data[key] = value;
            });

            const response = await fetch(this.endpoint, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify(data),
            });

            if (!response.ok) throw new Error("Ошибка отправки");

            await this.handleSuccessAndClose();
        } catch (error) {
            if (this.submitBtn) {
                const originalText = this.submitBtn.textContent;
                this.submitBtn.textContent = "❌ Ошибка";
                this.submitBtn.style.backgroundColor = "#ef4444";
                this.submitBtn.style.color = "white";

                setTimeout(() => {
                    if (this.submitBtn) {
                        this.submitBtn.textContent = originalText;
                        this.submitBtn.style.backgroundColor = "";
                        this.submitBtn.style.color = "";
                    }
                }, 1500);
            }
            console.error("Ошибка отправки:", error);
        } finally {
            if (this.submitBtn) {
                setTimeout(() => {
                    if (this.submitBtn) {
                        this.submitBtn.disabled = false;
                    }
                }, 2000);
            }
        }
    }

    // Метод для блокировки с сохранением позиции
    private lockBody(): void {
        // Сохраняем текущую позицию прокрутки
        this.scrollPosition = window.pageYOffset;
        
        // Применяем стили для блокировки
        document.body.style.overflow = 'hidden';
        document.body.style.position = 'fixed';
        document.body.style.top = `-${this.scrollPosition}px`;
        document.body.style.width = '100%';
    }

    // Метод для разблокировки с восстановлением позиции
    private unlockBody(): void {
        // Убираем стили
        document.body.style.overflow = '';
        document.body.style.position = '';
        document.body.style.top = '';
        document.body.style.width = '';
        
        // Восстанавливаем позицию прокрутки
        window.scrollTo(0, this.scrollPosition);
    }

    public open(title: string = "", service: string = ""): void {
        if (
            this.formContainer &&
            this.formContainer.innerHTML.includes("Спасибо")
        ) {
            this.quickRefreshForm();
        }

        if (title) {
            if (this.titleElement) {
                this.titleElement.textContent = title;
            }
            if (this.formTitleInput) {
                this.formTitleInput.value = title;
            }
        }

        if (service && this.serviceInput) {
            this.serviceInput.value = service;
        }

        // Блокируем body с сохранением позиции
        this.lockBody();

        this.overlay.classList.add("active");
        this.overlay.setAttribute("aria-hidden", "false");

        setTimeout(() => {
            this.nameInput?.focus();
        }, 300);
    }

    public close(): void {
        this.overlay.classList.remove("active");
        this.overlay.setAttribute("aria-hidden", "true");

        // Разблокируем body и восстанавливаем позицию
        this.unlockBody();

        setTimeout(() => {
            if (!this.isOpen()) {
                this.quickRefreshForm();
            }
        }, 300);
    }

    public isOpen(): boolean {
        return this.overlay.classList.contains("active");
    }
}

    // Инициализация
    document.addEventListener("DOMContentLoaded", () => {
        const popupElement = document.getElementById("popup-form");
        if (popupElement) {
            (window as any).popupForm = new PopupForm(popupElement);
        }
    });
</script>

<script is:inline>
    // Экспорт глобального API для вызова из любого места
    window.openPopup = function (title, service) {
        document.dispatchEvent(
            new CustomEvent("open-popup", {
                detail: { title, service },
            }),
        );
    };
</script>
<script is:inline>
    function handlePopupFromURL() {
        const hash = window.location.hash;

        if (!hash.includes("popup=")) return;

        const params = new URLSearchParams(hash.replace("#", ""));
        const popupType = params.get("popup");

        if (!popupType) return;

        // небольшая задержка — чтобы DOM и PopupForm точно были готовы
        setTimeout(() => {
            window.openPopup?.(
                popupType === "audit" ? "Бесплатный аудит" : "",
                popupType,
            );
        }, 300);

        // очищаем hash, чтобы не открывался снова при обновлении
        history.replaceState(null, "", window.location.pathname);
    }

    // при первой загрузке
    document.addEventListener("DOMContentLoaded", handlePopupFromURL);

    // если вдруг меняется hash (SPA/навигация)
    window.addEventListener("hashchange", handlePopupFromURL);
</script>
