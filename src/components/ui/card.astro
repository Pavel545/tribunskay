---
export interface Props {
    srcIcon: string;
    text: string;
    className?: string;
}

const { srcIcon, text, className = "" } = Astro.props;
---

<div class={`card ${className}`}>
    <div class="imgBox">
        <img class="cardImg" src={srcIcon} alt="" />
    </div>
    <p class="t20">
        {text}
    </p>
</div>

<style>
    .card {
        background: rgba(255, 255, 255, 0.02);
        border-radius: 1px;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 45px;

        padding: 50px;
    }
    .card .t20 {
        text-align: center;
    }
    .imgBox {
        width: 120px;
        height: 120px;
        overflow: hidden;
    }

    .cardImg {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }
</style>
