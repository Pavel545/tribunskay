---

export interface Props {
  videoSrc?: string;
  id?:string;
  poster?: string;
  className?: string;
  children?: any;
}

const { videoSrc, id, poster, className = '' } = Astro.props;
---

<section id={id} class={`video-section ${className}`} aria-label="Секция с фоновым видео">
  <!-- Фоновое видео -->
  <div class="video-background">
    <video 
      src={videoSrc}
      poster={poster}
      autoplay 
      muted 
      loop 
      playsinline
    >
      <!-- fallback на случай, если видео не поддерживается -->
      Ваш браузер не поддерживает видео.
    </video>
  </div>

  <!-- Контент поверх видео -->
  <div class="content-overlay">
    <div class="container">
      <slot />
    </div>
  </div>
</section>

<style is:global>
  .video-section {
    position: relative;
    width: 100%;
    min-height: 100vh; /* или можно задать конкретную высоту */
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: -2px;socText
  }

  .video-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .video-background video {
    width: 100%;
    height: 100%;
    object-fit: cover; /* видео покрывает всю область */
    object-position: center;
    pointer-events: none;
  }

  .content-overlay {
    position: absolute;
    left: 0;
    top: 0;

    z-index: 2;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(271deg, rgba(10, 10, 10, 0) 0%, #0a0a0ae6 60.77% 80.77%);  
  }

</style>