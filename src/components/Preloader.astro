---
// components/Preloader.astro
interface Props {
  show?: boolean;
  duration?: number;
  spinnerType?: "spinner" | "text" | "logo";
  customText?: string;
}

const { 
  show = true, 
  duration = 3000,
  spinnerType = "spinner",
  customText = "ЗАГРУЗКА..."
} = Astro.props;
---

{show && (
  <div 
    id="global-preloader" 
    class="preloader"
    data-duration={duration}
  >
    <div class="preloader-container">
      {spinnerType === "spinner" && (
        <div class="preloader-spinner"></div>
      )}
      {spinnerType === "text" && (
        <div class="preloader-text">{customText}</div>
      )}
      {spinnerType === "logo" && (
        <img src="/logo.svg" alt="Logo" class="preloader-logo" />
      )}
    </div>
  </div>
)}

<style>
  .preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--temnyy, #282631);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    transition: opacity 0.5s ease, visibility 0.5s ease;
    opacity: 1;
    visibility: visible;
    pointer-events: none;
  }

  .preloader.hide {
    opacity: 0;
    visibility: hidden;
  }

  .preloader-container {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .preloader-spinner {
    width: 60px;
    height: 60px;
    border: 4px solid var(--svetlo-seryy, #c8c8c8);
    border-top: 4px solid var(--zheltyy, #ffbf00);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  .preloader-text {
    font-family: "Inter", sans-serif;
    font-size: 16px;
    color: var(--belyy, #fff);
    letter-spacing: 2px;
    animation: pulse 1.5s ease infinite;
  }

  .preloader-logo {
    width: 80px;
    height: auto;
    animation: pulse 1.5s ease infinite;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.3; transform: scale(0.95); }
    50% { opacity: 1; transform: scale(1); }
  }
</style>

<script>
  const preloader = document.getElementById('global-preloader');
  const content = document.getElementById('app-content');
  
  // Получаем duration из data-атрибута
  const duration = preloader ? parseInt(preloader.getAttribute('data-duration') || '3000') : 3000;

  const hidePreloader = () => {
    if (!preloader) return;
    
    preloader.classList.add('hide');
    setTimeout(() => {
      if (preloader) preloader.style.display = 'none';
    }, 500);
    
    if (content) content.classList.add('visible');
  };

  if (document.readyState === 'complete') {
    hidePreloader();
  } else {
    window.addEventListener('load', hidePreloader);
  }

  setTimeout(hidePreloader, duration);
</script>