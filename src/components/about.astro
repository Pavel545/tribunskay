<style>
    /* Стили для бегущей строки */
    .marquee {
        width: 100%;
        overflow: hidden;
        padding: 15px 0;
        margin-top: 40px; /* Отступ сверху, если нужен */
    }

    .marquee__inner {
        display: flex;
        animation: scroll 30s linear infinite; /* Управление скоростью здесь */
        white-space: nowrap;
    }

    .marquee__inner span {
        font-family: var(--second-family);
        font-weight: 700;
        font-size: clamp(40px, 8vw, 150px);
        line-height: 90%;
        text-transform: uppercase;
        color: #101010;
    }

    @keyframes scroll {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(
                -50%
            ); /* Перемещаемся ровно на половину ширины, т.к. у нас 10 повторов */
        }
    }

    /* Ваши исходные стили (я немного подправил right grid) */
    .content {
        display: grid;
        grid-template-columns: 1fr 1fr;
       gap: clamp(40px, 8vw, 150px);
        padding: 60px 0;
    }

    .right {
        display: grid;
        grid-template-columns: repeat(
            2,
            1fr
        ); /* Исправлено: 2 колонки равной ширины */
        gap: 20px;
        row-gap: clamp(30px, 6vw, 85px);
    }

    .rTitle {
        font-family: var(--second-family);
        font-weight: 700;
        font-size: 40px;
        line-height: 110%;
        text-transform: uppercase;
        color: var(--zheltyy);
        padding-bottom: 20px;
        border-bottom: 1px solid #ffffff41;
    }

    .rText {
        font-weight: 400;
        font-size: 16px;
        line-height: 120%;
        color: #939393;
        padding-top: 15px;
    }

    /* =========================
   TABLET
========================= */
@media (max-width: 1024px) {
    .content {
        grid-template-columns: 1fr;
        gap: 60px;
        padding: 40px 0;
    }

    .left {
        max-width: 600px;
    }

    .right {
        grid-template-columns: repeat(2, 1fr);
        row-gap: 40px;
    }

    .marquee__inner span {
        font-size: clamp(60px, 10vw, 120px);
        will-change: transform;
        animation-play-state: paused;
    }
}

/* =========================
   MOBILE
========================= */
@media (max-width: 640px) {
    .content {
        gap: 40px;
        padding: 30px 0;
    }

    .right {
        grid-template-columns: 1fr;
        row-gap: 30px;
    }

    .rItem {
        text-align: center;
    }

    .rTitle {
        font-size: clamp(24px, 6vw, 32px);
    }

    .rText {
        font-size: 14px;
    }

    .marquee {
        margin-top: 20px;
        padding: 10px 0;
    }

    .marquee__inner span {
        font-size: clamp(40px, 12vw, 80px);
    }
}
</style>
