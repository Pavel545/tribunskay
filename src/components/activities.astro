---
import Card from "./ui/card.astro";
import UniversalAnimated from "./ui/framer-motion/UniversalAnimated";

const cards = [
    {
        icon: "/icons/activities/1.png",
        Text: "Вклад в формирование финансовой грамотности у будущих поколений",
    },
    {
        icon: "/icons/activities/2.png",
        Text: "Спикер по финансовой грамотности в высших учебных заведениях",
    },
    {
        icon: "/icons/activities/3.png",
        Text: "Публикую статьи и полезные материалы по финансовому планированию в СМИ и блогах",
    },
    {
        icon: "/icons/activities/4.png",
        Text: "Организую мастер-классы и тренинги для молодежи и предпринимателей",
    },
];
---

<section class="activities" id="activities">
    <div class="container">
        <UniversalAnimated
            client:load
            type="scroll"
            direction="left"
            duration={0.87}
            delay={0.3}
        >
            <h2 class="h2">
                Общественная <span class="yellow">деятельность</span>
            </h2>
        </UniversalAnimated>

        <div class="content">
            {
                cards.map((e, i) => (
                    <UniversalAnimated
                        client:load
                        type="scroll"
                        direction="up"
                        duration={0.87}
                        delay={0.6 + i * 0.1}
                    >
                        <Card srcIcon={e.icon} text={e.Text} />
                    </UniversalAnimated>
                ))
            }
        </div>
    </div>
</section>

<style>
    .activities {
        padding: 130px 0;

        border-top: 1px solid #ffffff37;
    }
    .content {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));

        gap: 10px;
        padding: 120px 0;
    }

    @media (max-width: 1024px) {
        .content {
            grid-template-columns: repeat(2, 1fr);
            padding: 90px 0;
        }
    }

    @media (max-width: 640px) {
        .content {
            grid-template-columns: repeat(1, 1fr);
            padding: 0;
        }
    }
</style>
