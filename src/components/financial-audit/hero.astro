---
import VideoBackground from "../ui/VideoBackground.astro";
---

<VideoBackground poster="/img/financial-audit/fonHero.jpg">
    <!-- Весь контент из hero секции -->
    <div class="gird">
        <div class="grid-left">
            <h1 class="title">
                Финансовый <br /><span class="titleSp">аудит</span>
            </h1>
            <ul class="list">
                <li class="list_item">
                    Онлайн-встреча с профессиональным финансистом
                </li>
                <li class="list_item">
                    Цель встречи: найти качественные решения
                </li>
                <li class="list_item">Результат: план действий</li>
            </ul>

            <div class="butBox">
                <button style="--bg:var(--zheltyy)" class="butt"
                    >Записаться на аудит</button
                >
            </div>
        </div>

        <div class="grid-right"></div>
    </div>
</VideoBackground>

<style>
    .vizitka {
        position: absolute;
        right: 0;
        bottom: 10%;
        padding: 26px;
        padding-right: 12vh;
        background: linear-gradient(
            270deg,
            #0a0a0abd 60.07%,
            rgba(10, 10, 10, 0) 100%
        );
    }

    .vizitka_title {
        font-family: var(--second-family);
        font-weight: 700;
        font-size: clamp(24px, 2vw, 40px);
        line-height: 110%;
        text-transform: uppercase;
        text-align: right;
        color: var(--zheltyy);
    }

    .vizitka_text {
        font-family: var(--font-family);
        font-weight: 400;
        font-size: 20px;
        line-height: 130%;
        text-align: right;
        color: var(--belyy);
    }
    .gird {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        align-items: center;
    }

    .grid-right {
        /* position: relative; */
    }

    .bos-box {
        height: 100%;
        position: absolute;
        top: 0;
        right: 5%;
        width: auto;
    }

    .bos-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .title {
        font-family: var(--second-family);
        font-weight: 700;
        font-size: clamp(40px, 5vw, 90px);
        line-height: 100%;
        text-transform: uppercase;
        color: var(--belyy);
    }

    .titleSp {
        font-family: var(--second-family);
        font-weight: 700;
        font-size: clamp(40px, 5.5vw, 110px);
        line-height: 111%;
        text-transform: uppercase;
        color: var(--zheltyy);
    }

    .list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .list_item {
        color: var(--svetlo-seryy);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .list_item::before {
        content: url("/icons/rub.png");
        width: 20px;
        height: 20px;
    }

    .butBox {
        display: flex;
        gap: 20px;
        margin-top: 80px;
    }
</style>
