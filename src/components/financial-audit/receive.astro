<section class="receive">
    <div class="container">
        <h2 class="h2">
            после аудита <span class="yellow">вы получите</span>
        </h2>

        <div class="receive_content">
            <div class="receive_img">
                <img
                    src="/img/financial-audit/receive.jpg"
                    alt="Вопросы на которые ответит финансовый аудит"
                />
            </div>

            <div class="items">
                <div class="item">
                    <h3 class="item_title">Список проблемных зон</h3>

                    <ul class="list">
                        <li class="listItem">Точки потери денег</li>
                        <li class="listItem">«Серые зоны» в учёте</li>
                        <li class="listItem">
                            Ключевые финансовые риски компании
                        </li>
                    </ul>
                </div>
                <div class="item">
                    <h3 class="item_title">Ориентир для развития</h3>

                    <ul class="list">
                        <li class="listItem">
                            Наиболее прибыльные направления
                        </li>
                        <li class="listItem">Процессы для масштабирования</li>
                        <li class="listItem">
                            Действия для быстрого результата
                        </li>
                    </ul>
                </div>
                <div class="item">
                    <h3 class="item_title">Ориентир для развития</h3>

                    <ul class="list">
                        <li class="listItem">
                            Какие инструменты должны быть внедрены
                        </li>
                        <li class="listItem">
                            Как использовать учёт для роста прибыли
                        </li>
                        <li class="listItem">
                            Как должны быть выстроены процессы в финансах
                        </li>
                    </ul>
                </div>
                <div class="item">
                    <h3 class="item_title">План действий</h3>

                    <ul class="list">
                        <li class="listItem">
                            С чего начать внедрение инструментов
                        </li>
                        <li class="listItem">
                            Какие показатели взять в работу
                        </li>
                        <li class="listItem">
                            Кого нанять и кому делегировать задачи
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="buttBox">
            <button
                class="butt"
                style="--bg:var(--zheltyy);--bgH:var(--oranzhevyy)"
            >
                Записаться на аудит
            </button>
        </div>
    </div>
</section>

<style>
 /* Базовые стили (десктоп) */
.list {
    margin-left: 25px;
}

.buttBox {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.listItem {
    font-weight: 400;
    font-size: 16px;
    leading-trim: NONE;
    line-height: 120%;
    letter-spacing: 0%;
    color: #787878;
    list-style: disc;
    margin-bottom: 6px;
}

.listItem::marker {
    color: var(--zheltyy);
}

.receive {
    padding: 140px 0;
}

.item_title {
    font-weight: 400;
    font-size: 25px;
    line-height: 120%;
    letter-spacing: 0%;
}

.item {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 60px 30px;
    background: var(--belyy);
}

.items {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
}

.receive_content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 35px;
    margin: 60px 0;
}

.receive_img {
    width: 100%;
    aspect-ratio: 4 / 3;
}

.receive_img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* Планшеты (768px - 1023px) */
@media screen and (max-width: 1023px) {
    .receive {
        padding: 100px 0;
    }

    .receive_content {
        gap: 25px;
        margin: 40px 0;
    }

    .items {
        gap: 15px;
    }

    .item {
        padding: 40px 20px;
        gap: 15px;
    }

    .item_title {
        font-size: 22px;
    }

    .listItem {
        font-size: 14px;
    }

    .list {
        margin-left: 20px;
    }
}

/* Мобильные устройства (до 767px) */
@media screen and (max-width: 767px) {
    .receive {
        padding: 60px 0;
    }

    /* Меняем колонки на 1 */
    .receive_content {
        grid-template-columns: 1fr;
        gap: 30px;
        margin: 30px 0;
    }

    /* Меняем порядок: картинка сверху, текст снизу */
    .receive_content > :first-child {
        order: 1;
    }

    .receive_content > :last-child {
        order: 2;
    }

    .items {
        grid-template-columns: 1fr;
        gap: 15px;
    }

    .item {
        padding: 30px 20px;
        gap: 12px;
    }

    .item_title {
        font-size: 20px;
    }

    .listItem {
        font-size: 14px;
        margin-bottom: 4px;
    }

    .list {
        margin-left: 18px;
    }

    .receive_img {
        aspect-ratio: 16 / 9;
    }
}

/* Маленькие мобильные (до 480px) */
@media screen and (max-width: 480px) {
    .receive {
        padding: 40px 0;
    }

    .receive_content {
        gap: 20px;
        margin: 20px 0;
    }

    .item {
        padding: 25px 15px;
        gap: 10px;
    }

    .item_title {
        font-size: 18px;
    }

    .listItem {
        font-size: 13px;
    }

    .list {
        margin-left: 15px;
    }

    .buttBox {
        margin-top: 10px;
    }
}
</style>
