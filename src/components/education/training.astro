---
import FormatCard from "../ui/FormatCard.astro";
---

<section class="training">
    <div class="container">
        <h2 class="h2 trainingTitle">
            Выберите удобный <span class="yellow">формат обучения</span>
        </h2>

        <div class="trainingContent">
            <FormatCard
                title="Базовый"
                color="#282631"
                who="Кто хочет понять основы самостоятельно"
                cost="45 000 ₽"
                item={["Доступ к видео-урокам и материалам", "Шаблоны 3-х главных отчетов"]}
                itemDop={["Справочник KPI"]}
            />
             <FormatCard
                title="Профессиональный"
                color="#FFBF00"
                who="Собственники, которым нужно внедрение под ключ"
                cost="75 000 ₽"
                item={["Всё из тарифа «Базовый»", "Индивидуальные сессии по внедрению систем учета", 
                    "Живые разборы и Q&A сессии"
                ]}
                itemDop={["Постановка Управленческого Учета гайд"]}
            />
        </div>
    </div>
</section>

<style>
  .training {
        padding: 120px 0;
        background: var(--svetlyy);
    }
    .trainingTitle {
        text-align: center;
    }

    .trainingContent{
        display: grid;
        gap: 20px;
        margin-top: 60px;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    }
    
    /* Адаптив для секции */
    @media (max-width: 768px) {
        .training {
            padding: 60px 0;
        }
        
        .trainingTitle {
            font-size: 32px;
        }
        
        .trainingContent {
            margin-top: 40px;
            gap: 15px;
            grid-template-columns: 1fr;
        }
    }
    
    @media (max-width: 480px) {
        .training {
            padding: 40px 0;
        }
        
        .trainingTitle {
            font-size: 28px;
        }
        
        .trainingContent {
            margin-top: 30px;
            gap: 20px;
        }
    }
</style>
