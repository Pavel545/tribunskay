---
import type { Course } from "../../data/courses";
import FormatCard from "../ui/FormatCard.astro";
const {course} = Astro.props as { course: Course };

---

<section class="training">
  <div class="container">
    <h2 class="h2 trainingTitle">
      Выберите удобный <span class="yellow">формат обучения</span>
    </h2>

    <div class="trainingContent">
      <FormatCard
        title={course.tariffs.basic.title}
        color={course.tariffs.basic.color}
        who={course.tariffs.basic.who}
        cost={course.tariffs.basic.cost}
        item={course.tariffs.basic.items}
        itemDop={course.tariffs.basic.dopItems}
      />
      <FormatCard
        title={course.tariffs.professional.title}
        color={course.tariffs.professional.color}
        who={course.tariffs.professional.who}
        cost={course.tariffs.professional.cost}
        item={course.tariffs.professional.items}
        itemDop={course.tariffs.professional.dopItems}
        isHighlighted={course.tariffs.professional.isHighlighted}
      />
    </div>
  </div>
</section>

<style>
    .h2 {
       color: var(--temnyy);
    }
  .training {
        padding: 120px 0;
        background: var(--svetlyy);
    }
    .trainingTitle {
        text-align: center;
    }

    .trainingContent{
        display: grid;
        gap: 20px;
        margin-top: 60px;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    }
    
    /* Адаптив для секции */
    @media (max-width: 768px) {
        .training {
            padding: 60px 0;
        }
        
        .trainingTitle {
            font-size: 32px;
        }
        
        .trainingContent {
            margin-top: 40px;
            gap: 15px;
            grid-template-columns: 1fr;
        }
    }
    
    @media (max-width: 480px) {
        .training {
            padding: 40px 0;
        }
        
        .trainingTitle {
            font-size: 28px;
        }
        
        .trainingContent {
            margin-top: 30px;
            gap: 20px;
        }
    }
</style>
