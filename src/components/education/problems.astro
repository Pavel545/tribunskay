---
import type { Course } from "../../data/courses";

const {course} = Astro.props as { course: Course };

---

<section class="problems" id="problems">
  <div class="container">
    <h2 class="h2 problemsTitle">
      {course.problems.title.split(' ').slice(0, -1).join(' ')} <br />
      <span class="yellow"> {course.problems.title.split(' ').slice(-1).join(' ')} </span>
    </h2>

    <div class="problemsContent">
      {course.problems.items.map((item, index) => (
        <div class="item">
          <div class="iconBox">
            <img class="icon" src={item.icon} alt={item.title} />
          </div>
          <h3 class="itemTitle">{item.title}</h3>
          <p class="itemText">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>

    .h2 {
       color: var(--temnyy);
    }
    .problems {
        padding: 140px 0;
    }
    .problemsTitle {
        text-align: center;
    }

    .itemText {
        font-weight: 400;
        font-size: 16px;
        line-height: 120%;
        letter-spacing: 0%;
        text-align: center;
        color: var(--seryy);
        max-width: 322px;
    }

    .item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 30px;

        padding: 2%;
        border-radius: 20px;
    }

    .itemTitle {
        font-weight: 400;
        font-size: 25px;
        line-height: 120%;
        letter-spacing: 0%;
        text-align: center;
    }

    .problemsContent {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: clamp(10px, 4vw, 20px);

        margin-top: 80px;
    }
</style>
