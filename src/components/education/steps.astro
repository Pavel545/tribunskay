---
import type { Course } from "../../data/courses";

const {course} = Astro.props as { course: Course };

---

<section class="steps" id="steps">
  <div class="container">
    <h2 class="h2 stepsTitle">
      {course.steps.title}<br />
      <span class="yellow"> {course.steps.subtitle} </span>
    </h2>

    <div class="stepsContent">
      {course.steps.items.map((item, index) => {
        // Распределяем элементы по сетке
        const gridArea = `item${index + 1}`;
        const isImage = index === 2 || index === 3; // 3-й и 4-й элементы — изображения
        
        if (isImage && course.steps.images) {
          const imageIndex = index === 2 ? 0 : 1;
          return (
            <div class={`stepItemImg ${gridArea}`}>
              <img src={course.steps.images[imageIndex]} alt="" />
            </div>
          );
        }
        
        return (
          <div class={`stepItemText ${gridArea}`}>
            <div class="count">{item.count}</div>
            <h3 class="stepItemTextTitle">{item.title}</h3>
            <p class="stepItemTextP">{item.description}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
    .h2 {
       color: var(--temnyy);
    }
    .stepsContent {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: clamp(10px, 3vw, 20px);
        margin-top: 60px;
        grid-template-areas:
            "item1 item2 item3 item3"
            "item4 item4 item5 item6";
    }

    .item1 {
        grid-area: item1;
    }
    .item2 {
        grid-area: item2;
    }
    .item3 {
        grid-area: item3;
    }
    .item4 {
        grid-area: item4;
    }
    .item5 {
        grid-area: item5;
    }
    .item6 {
        grid-area: item6;
    }

    .stepItemImg img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* Адаптив */
    @media (max-width: 768px) {
        .stepsContent {
            grid-template-columns: 1fr;
            grid-template-areas:
                "item1"
                "item2"
                "item3"
                "item4"
                "item5"
                "item6";
        }
    }
    .stepItemTextP {
        font-weight: 400;
        font-size: 16px;
        line-height: 120%;
        letter-spacing: 0%;
        color: var(--seryy);
    }
    .stepItemTextTitle {
        font-weight: 400;
        font-size: 25px;
        line-height: 120%;
        letter-spacing: 0%;
    }
    .count {
        font-family: var(--second-family);
        font-weight: 700;
        font-style: Bold;
        font-size: 40px;
        line-height: 110.00000000000001%;
        letter-spacing: 0%;
        text-transform: uppercase;
        color: var(--temnyy);
        opacity: 0.5;
    }

    .stepItemText {
        display: flex;
        flex-direction: column;
        gap: 20px;
        padding: 30px;
        background-color: var(--belyy);
    }
    .stepsTitle {
        text-align: center;
    }



    .stepsPs {
        font-weight: 400;
        font-size: 25px;
        line-height: 120%;
        letter-spacing: 0%;
        text-align: center;
        color: var(--seryy);
    }
    .steps {
        background-color: var(--svetlyy);
        padding: 140px 0;
    }
</style>
