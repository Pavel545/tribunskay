---
import type { Course } from "../../data/courses";
import VideoBackground from "../ui/VideoBackground.astro";

const { course } = Astro.props as { course: Course };


---

<VideoBackground  poster={course?.hero?.img || "/img/education/fonHero.jpg"}
  posterMobile={course?.hero?.imgMob}>
    <!-- Весь контент из hero секции -->
    <>
        <div class="grid">
            <div class="grid-left">
                <!-- <div class="direction-badge">{course.direction}</div> -->
                <h1 class="title">{course.hero.title}</h1>
                <p class="vizitka_text">{course.hero.subtitle}</p>
                <div class="butBox">
                    <button data-popup
                        data-popup-title={course.hero.ctaButton} style="--bg:var(--svetlo-seryy)" class="butt">
                        {course.hero.ctaButton}
                    </button>
                </div>
            </div>
            <div class="grid-right"></div>
        </div>

       {course?.formats && <div class="adItems">
            {
                course.formats.items.map((item) => (
                    <div class="adItem">
                        <div class="iconBox">
                            <img src={item.icon} alt={item.title} />
                        </div>
                        <p class="adItemTitle">{item.title}</p>
                    </div>
                ))
            }
        </div>}
    </>
</VideoBackground>

<style>
    
    .adItemTitle {
        font-weight: 400;
        font-size: clamp(12px, 1.2rem, 20px);
        line-height: 120%;
        letter-spacing: 0%;
        color: var(--belyy);
        text-align: center;
    }

    .adItems {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-top: 120px;
    }

    .adItem {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 7px;
        padding: 20px;
        background: #ffffff3f;
        backdrop-filter: blur(10px);
        transition: transform 300ms ease;
    }

    .adItem:hover {
        transform: translateY(-5px);
    }

    .vizitka {
        position: absolute;
        right: 0;
        bottom: 10%;
        padding: 26px;
        padding-right: 12vh;
        background: linear-gradient(
            270deg,
            #0a0a0abd 60.07%,
            rgba(10, 10, 10, 0) 100%
        );
    }

    .vizitka_title {
        font-family: var(--second-family);
        font-weight: 700;
        font-size: clamp(24px, 2vw, 40px);
        line-height: 110%;
        text-transform: uppercase;
        text-align: right;
        color: var(--zheltyy);
    }

    .vizitka_text {
        font-weight: 400;
        font-size: 25px;
        line-height: 120%;
        letter-spacing: 0%;
        color: var(--svetlo-seryy);
        max-width: 712px;
    }

    .grid {
        display: grid;
        grid-template-columns: 3.2fr 1fr;
        align-items: center;
    }

    .title {
        font-family: var(--second-family);
        font-weight: 700;
        font-size: clamp(24px, 3vw, 45px);
        line-height: 1,2;
        max-width: 1000px;
        text-transform: uppercase;
        color: var(--belyy);
    }

    .butBox {
        display: flex;
        gap: 20px;
        margin-top: 80px;
    }

    .iconBox img {
        max-width: 100%;
        height: auto;
    }

    /* ===== АДАПТИВ ===== */

    /* Планшеты (до 1024px) */
    @media (max-width: 1024px) {
        .grid {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .vizitka_text {
            font-size: 22px;
            max-width: 100%;
        }

        .butBox {
            margin-top: 50px;
        }

        .adItems {
            margin-top: 80px;
            gap: 15px;
        }

        .adItemTitle {
            font-size: 20px;
        }

        .adItem {
            padding: 10px;
        }
    }

    /* Мобильные устройства (до 768px) */
    @media (max-width: 768px) {
        .grid {
            gap: 30px;
        }

        .title {
            font-size: clamp(32px, 6vw, 40px);
            br {
                display: none;
            }
        }

        .vizitka_text {
            font-size: 18px;
            line-height: 130%;
        }

        .butBox {
            margin-top: 40px;
            flex-direction: column;
            gap: 15px;
        }

        .butBox button {
            width: 100%;
        }

        .adItems {
            grid-template-columns: repeat(2, 1fr);
            margin-top: 60px;
            gap: 15px;
        }

        .adItemTitle {
            font-size: 16px;
            text-align: center;
        }

        .adItem {
            padding: 12px;
        }

        .iconBox img {
            width: 40px;
            height: 40px;
        }
    }

    /* Маленькие мобильные (до 480px) */
    @media (max-width: 480px) {
        .grid {
            gap: 20px;
        }

        .title {
            font-size: clamp(28px, 5vw, 32px);
            br {
                display: none;
            }
        }

        .vizitka_text {
            font-size: 16px;
        }

        .butBox {
            margin-top: 30px;
        }

        .adItems {
            grid-template-columns: 1fr;
            margin-top: 40px;
            gap: 12px;
        }

        .adItem {
            flex-direction: row;
            justify-content: center;
            gap: 12px;
            padding: 12px 20px;
        }

        .adItemTitle {
            font-size: 16px;
            margin-bottom: 0;
        }

        .iconBox img {
            width: 32px;
            height: 32px;
        }
    }

   
</style>
