---
import type { Course } from "../../data/courses";

const {course} = Astro.props as { course: Course };
---

<section class="faq-accordion">
  <div class="container">
    <h2 class="h2">
      {course.steps.title}<br />
      <span class="yellow">{course.steps.subtitle}</span>
    </h2>

    <div class="faq-accordion_content">
      <!-- <div class="faq-accordion_img">
        <img
          src="/img/financial-audit/faq.jpg"
          alt="Вопросы на которые ответит финансовый аудит"
        />
      </div> -->

      <div class="accordion-items">
        {course.steps.items.map((item, index) => (
          <div class="accordion-item" data-accordion-item>
            <div class="accordion-header">
              <p class="count">{item.count}</p>
              <p class="text">{item.title}</p>
              <img class="itemIcon" src="/icons/go.svg" alt="Переход" />
            </div>
            <div class="accordion-content">
              <p class="accordion-description">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Базовые стили (десктоп) */
  .faq-accordion {
    padding: 140px 0;
    background-color: var(--svetlyy);
  }

  .itemIcon {
    width: 40px;
    height: 40px;
    transition: transform 0.3s ease;
  }

  .accordion-item.active .itemIcon {
    transform: rotate(90deg);
  }

  .text {
    font-weight: 400;
    font-size: 25px;
    line-height: 120%;
    letter-spacing: 0%;
    flex: 1;
    padding: 10px;
  }

  .count {
    font-family: var(--second-family);
    font-weight: 700;
    font-style: Bold;
    font-size: 40px;
    line-height: 110%;
    letter-spacing: 0%;
    text-transform: uppercase;
    color: var(--seryy);
    opacity: 0.5;
    min-width: 70px;
  }

  .accordion-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 15px;
    border-bottom: 1px solid #0a0a0a24;
    padding: 10px 8px;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .accordion-header:hover {
    background-color: rgba(10, 10, 10, 0.02);
  }

  .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease-out, padding 0.3s ease;
    padding: 0 0 0 70px;
  }

  .accordion-item.active .accordion-content {
    max-height: 300px;
    padding: 15px 0 20px 70px;
  }

  .accordion-description {
    font-weight: 400;
    font-size: 18px;
    line-height: 140%;
    letter-spacing: 0%;
    color: var(--seryy);
    margin: 0;
  }

  .accordion-items {
    display: flex;
    flex-direction: column;
  }

  .faq-accordion_content {
    display: grid;
    grid-template-columns: 1fr ;
    gap: 35px;
    margin: 60px 0;
  }

  .faq-accordion_img {
    width: 100%;
    height: 500px;
  }

  .faq-accordion_img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .h2 {
    color: var(--temnyy);
    text-align: center;
  }

  /* Планшеты (768px - 1023px) */
  @media screen and (max-width: 1023px) {
    .faq-accordion {
      padding: 100px 0;
    }

    .faq-accordion_content {
      gap: 25px;
      margin: 40px 0;
    }

    .text {
      font-size: 20px;
      padding: 8px;
    }

    .count {
      font-size: 32px;
      min-width: 60px;
    }

    .itemIcon {
      width: 32px;
      height: 32px;
    }

    .accordion-content {
      padding: 0 0 0 60px;
    }

    .accordion-item.active .accordion-content {
      padding: 15px 0 20px 60px;
    }

    .accordion-description {
      font-size: 16px;
    }
  }

  /* Мобильные устройства (до 767px) */
  @media screen and (max-width: 767px) {
    .faq-accordion {
      padding: 60px 0;
    }

    .faq-accordion_content {
      grid-template-columns: 1fr;
      gap: 30px;
      margin: 30px 0;
    }

    .faq-accordion_content > :first-child {
      order: 1;
    }

    .faq-accordion_content > :last-child {
      order: 2;
    }

    .text {
      font-size: 16px;
      padding: 8px 6px;
    }

    .count {
      font-size: 24px;
      min-width: 50px;
    }

    .itemIcon {
      width: 28px;
      height: 28px;
    }

    .accordion-header {
      gap: 10px;
      padding: 12px 0;
    }

    .accordion-content {
      padding: 0 0 0 50px;
    }

    .accordion-item.active .accordion-content {
      padding: 12px 0 16px 50px;
    }

    .accordion-description {
      font-size: 14px;
    }
  }

  /* Маленькие мобильные (до 480px) */
  @media screen and (max-width: 480px) {
    .faq-accordion {
      padding: 40px 0;
    }

    .faq-accordion_content {
      gap: 20px;
      margin: 20px 0;
    }

    .text {
      font-size: 14px;
      padding: 6px 4px;
    }

    .count {
      font-size: 18px;
      min-width: 40px;
    }

    .itemIcon {
      width: 24px;
      height: 24px;
    }

    .accordion-header {
      gap: 8px;
      padding: 10px 0;
    }

    .accordion-content {
      padding: 0 0 0 40px;
    }

    .accordion-item.active .accordion-content {
      padding: 10px 0 14px 40px;
    }
  }

  /* Горизонтальная ориентация на мобильных */
  @media screen and (max-width: 767px) and (orientation: landscape) {
    .faq-accordion {
      padding: 40px 0;
    }

    .text {
      font-size: 15px;
    }

    .accordion-content {
      padding: 0 0 0 55px;
    }

    .accordion-item.active .accordion-content {
      padding: 12px 0 16px 55px;
    }
  }
</style>

<script>
  // Инициализация аккордеонов после загрузки страницы
  document.addEventListener('DOMContentLoaded', () => {
    const accordionItems = document.querySelectorAll('[data-accordion-item]');

    accordionItems.forEach((item) => {
      const header = item.querySelector('.accordion-header') as Element;

      header.addEventListener('click', () => {
        // Закрываем все остальные аккордеоны (опционально - для "один открыт за раз")
        // Раскомментируйте если нужно:
        accordionItems.forEach((otherItem) => {
          if (otherItem !== item && otherItem.classList.contains('active')) {
            otherItem.classList.remove('active');
          }
        });

        // Переключаем текущий
        item.classList.toggle('active');
      });
    });
  });
</script>