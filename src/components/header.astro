---
import { NAVIGATION, SOCIAL_LINKS } from "../config/constants";
---

<header class="header">
    <div class="container">
        <div class="inner">
            <!-- ЛОГО -->
            <a href="/" class="logo">
                <img src="/logo.png" alt="Логотип" />
            </a>

            <!-- НАВИГАЦИЯ -->
            <nav class="nav" id="nav">
                {NAVIGATION.map((item) => (
                    <a class="link" href={item.url}>
                        {item.text}
                    </a>
                ))}

                <!-- контакты внутри меню -->
                <div class="nav-bottom">
                    <a class="phone" href={SOCIAL_LINKS.tel.src}>
                        {SOCIAL_LINKS.tel.text}
                    </a>

                    <div class="socials">
                        <a class="soc" href="">
                            <img src="/icons/tg.png" alt="Telegram" />
                        </a>

                        <a class="soc socText" href="">
                            <img src="/12.png" alt="" />
                            <span>ПроФФинанс</span>
                        </a>
                    </div>
                </div>
            </nav>

            <!-- БУРГЕР -->
            <button class="burger" id="burger" aria-label="Меню">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </div>
</header>

<script>
    const burger = document.getElementById('burger');
    const nav = document.getElementById('nav');

  
    burger?.addEventListener('click', () => {
        burger.classList.toggle('active');
        nav.classList.toggle('active');
        document.body.classList.toggle('lock');
    });

    // закрытие по клику вне
    document.addEventListener('click', (e) => {
        if (!nav.contains(e.target) && !burger.contains(e.target)) {
            burger.classList.remove('active');
            nav.classList.remove('active');
            document.body.classList.remove('lock');
        }
    });
</script>

<style>
/* ===== BASE ===== */
.header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--chernyy);
}

.container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 20px;
}

.inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
}

/* ===== LOGO ===== */
.logo {
    width: 60px;
    height: 60px;
    flex-shrink: 0;
}

.logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

/* ===== NAV DESKTOP ===== */
.nav {
    display: flex;
    align-items: center;
    gap: 20px;
}

.link {
    font-size: 16px;
    color: var(--svetlo-seryy);
    text-decoration: none;
    position: relative;
}

.link::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0%;
    height: 2px;
    background: var(--zheltyy);
    transition: 0.3s;
}

.link:hover::after {
    width: 100%;
}

/* ===== NAV EXTRA ===== */
.nav-bottom {
    display: none;
}

.phone {
    color: var(--belyy);
    margin-top: 20px;
}

.socials {
    display: flex;
    gap: 10px;
    margin-top: 15px;
}

.soc {
    width: 40px;
    height: 40px;
    background: rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
}

.soc img {
    width: 20px;
    height: 20px;
}

.socText {
    width: auto;
    padding: 0 10px;
    gap: 8px;
}

.socText span {
    font-size: 14px;
}

/* ===== BURGER ===== */
.burger {
    display: none;
    width: 36px;
    height: 36px;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
}

.burger span {
    width: 100%;
    height: 2px;
    background: white;
    transition: 0.3s;
}

/* ANIMATION */
.burger.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
}
.burger.active span:nth-child(2) {
    opacity: 0;
}
.burger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
}

/* ===== MOBILE ===== */
@media (max-width: 768px) {
    .burger {
        display: flex;
    }

    .nav {
        position: fixed;
        top: 0;
        right: -100%;
        width: 80%;
        height: 100vh;
        background: #111;

        flex-direction: column;
        align-items: flex-start;

        padding: 100px 30px;
        gap: 20px;

        transition: 0.4s;
    }

    .nav.active {
        right: 0;
    }

    .nav-bottom {
        display: block;
        margin-top: auto;
    }

    .link {
        font-size: 18px;
    }
}

/* ===== BODY LOCK ===== */
body.lock {
    overflow: hidden;
}
</style>