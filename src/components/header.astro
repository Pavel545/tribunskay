---
import { NAVIGATION, SOCIAL_LINKS } from "../config/constants";
import "../styles/global.css";
---

<header class="header">
    <div class="container">
        <div class="inner">
            <!-- ЛОГО -->
            <a href="/" class="logo">
                <img src="/logo.png" alt="Логотип" />
            </a>

            <!-- НАВИГАЦИЯ -->
            <nav class="nav" id="nav">
                <div class="nav-links">
                    {
                        NAVIGATION.map((item, index) => (
                            <>
                                <a class="link" href={item.url}>
                                    {item.text}
                                </a>
                                {index < NAVIGATION.length - 1 && <span class="divider">|</span>}
                            </>
                        ))
                    }
                </div>

                <!-- контакты внутри меню -->
                <div class="nav-bottom">
                    <a class="phone" href={SOCIAL_LINKS.tel.src}>
                        {SOCIAL_LINKS.tel.text}
                    </a>

                    <div class="socials">
                        <!-- <a class="soc" href="">
                            <img src="/icons/tg.png" alt="Telegram" />
                        </a> -->

                        <a class="soc socText" href="">
                            <img src="/12.png" alt="" />
                            <span>ПроФФинанс</span>
                        </a>
                    </div>
                </div>
            </nav>

            <!-- БУРГЕР -->
            <button class="burger" id="burger" aria-label="Меню">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </div>
</header>

<script>
    const burger = document.getElementById("burger");
    const nav = document.getElementById("nav");

    burger?.addEventListener("click", (e) => {
        e.stopPropagation();
        burger.classList.toggle("active");
        nav?.classList.toggle("active");
        document.body.classList.toggle("lock");
    });

    // закрытие по клику вне
    document.addEventListener("click", (e) => {
        const target = e.target as Node;
        if (nav && burger && !nav.contains(target) && !burger.contains(target)) {
            burger.classList.remove("active");
            nav.classList.remove("active");
            document.body.classList.remove("lock");
        }
    });

    // закрытие по клику на ссылку
    const links = document.querySelectorAll(".link");
    links.forEach((link) => {
        link.addEventListener("click", () => {
            burger?.classList.remove("active");
            nav?.classList.remove("active");
            document.body.classList.remove("lock");
        });
    });
</script>

<style>
    /* ===== BASE ===== */
    .header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--chernyy);
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
    }



    .inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 80px;
        gap: 30px;
    }

    /* ===== LOGO ===== */
    .logo {
        width: 60px;
        height: 60px;
        flex-shrink: 0;
        transition: opacity 0.3s ease;
    }
    
    .logo:hover {
        opacity: 0.8;
    }

    .logo img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    /* ===== NAV DESKTOP ===== */
    .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .link {
        font-size: 16px;
        color: var(--svetlo-seryy);
        text-decoration: none;
        position: relative;
        transition: color 0.3s ease;
        white-space: nowrap;
    }

    .link:hover {
        color: var(--zheltyy);
    }

    .link::after {
        content: "";
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0%;
        height: 2px;
        background: var(--zheltyy);
        transition: 0.3s;
    }

    .link:hover::after {
        width: 100%;
    }

    /* ===== VERTICAL DIVIDER ===== */
    .divider {
        color: rgba(255, 255, 255, 0.2);
        font-size: 16px;
        line-height: 1;
        user-select: none;
    }

    /* ===== NAV EXTRA ===== */
    .nav-bottom {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-shrink: 0;
    }

    .phone {
        color: var(--belyy);
        text-decoration: none;
        font-size: 16px;
        transition: color 0.3s ease;
        white-space: nowrap;
    }
    
    .phone:hover {
        color: var(--zheltyy);
    }

    .socials {
        display: flex;
        gap: 10px;
    }

    .soc {
        width: 40px;
        height: 40px;
        background: rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        text-decoration: none;
    }
    
    .soc:hover {
        background: rgba(255, 191, 0, 0.2);
        transform: translateY(-2px);
    }

    .soc img {
        width: 20px;
        height: 20px;
    }

    .socText {
        width: auto;
        padding: 0 12px;
        gap: 8px;
    }

    .socText span {
        font-size: 14px;
        color: var(--belyy);
        font-weight: 500;
    }

    /* ===== BURGER ===== */
    .burger {
        display: none;
        width: 36px;
        height: 36px;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        z-index: 101;
        flex-shrink: 0;
    }

    .burger span {
        width: 24px;
        height: 2px;
        background: var(--belyy);
        transition: 0.3s;
        border-radius: 2px;
    }

    /* BURGER ANIMATION */
    .burger.active span:nth-child(1) {
        transform: rotate(45deg) translate(5px, 5px);
    }
    .burger.active span:nth-child(2) {
        opacity: 0;
    }
    .burger.active span:nth-child(3) {
        transform: rotate(-45deg) translate(5px, -5px);
    }

    /* ===== MOBILE ===== */
    @media (max-width: 1024px) {
        .nav-links {
            gap: 15px;
        }
        
        .link {
            font-size: 14px;
        }
        
        .divider {
            font-size: 14px;
        }
        
        .phone {
            font-size: 14px;
        }
    }

    @media (max-width: 768px) {
        .burger {
            display: flex;
        }

        .nav {
            position: fixed;
            top: 0;
            right: -100%;
            width: 85%;
            max-width: 400px;
            height: 100vh;
            background: var(--chernyy);
            z-index: 100;
            
            flex-direction: column;
            justify-content: flex-start;
            align-items: flex-start;
            
            padding: 100px 30px 40px;
            gap: 40px;
            
            transition: right 0.4s ease;
            box-shadow: -5px 0 30px rgba(0, 0, 0, 0.5);
        }

        .nav.active {
            right: 0;
        }

        .nav-links {
            flex-direction: column;
            align-items: flex-start;
            gap: 25px;
            width: 100%;
        }
        
        .divider {
            display: none;
        }

        .link {
            font-size: 20px;
            width: 100%;
        }
        
        .link::after {
            bottom: -6px;
        }

        .nav-bottom {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
            width: 100%;
            margin-top: auto;
        }
        
        .phone {
            font-size: 18px;
        }
        
        .socials {
            gap: 15px;
        }
        
        .soc {
            width: 44px;
            height: 44px;
        }
        
        .soc img {
            width: 22px;
            height: 22px;
        }
        
        .socText {
            padding: 0 15px;
            width: fit-content !important;

        }
        
        .socText span {
            font-size: 16px;
        }
    }

    @media (max-width: 480px) {
        .inner {
            height: 70px;
        }
        
        .logo {
            width: 50px;
            height: 50px;
        }
        
        .nav {
            width: 100%;
            padding: 80px 25px 30px;
        }
        
        .link {
            font-size: 18px;
        }
        
        .phone {
            font-size: 16px;
        }
    }

    /* ===== BODY LOCK ===== */
    body.lock {
        overflow: hidden;
    }
</style>