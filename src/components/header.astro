---
import { NAVIGATION, SOCIAL_LINKS } from "../config/constants";
---

<header class="header">
    <div class="container">
        <div class="content">
            <div class="content">
                <a href="/" class="logo">
                    <img src="/logo.png" alt="Логотип" />
                </a>

                <nav class="linkBox">
                    {
                        NAVIGATION.map((item) => (
                            <a class="linkH" href={item.url}>
                                {item.text}
                            </a>
                        ))
                    }
                </nav>
            </div>

            <div class="content">
                <a class="linkH" href={SOCIAL_LINKS.tel.src}
                    >{SOCIAL_LINKS.tel.text}</a
                >
                <a class="butSoc" href=""
                    ><img src="/icons/tg.png" alt="Tellegramm" /></a
                >
                <a class="butSoc" href=""
                    ><img class="icon" src="/12.png" alt="Tellegramm" /><span
                        >ПроФФинанс</span
                    ></a
                >
            </div>
        </div>
    </div>
</header>

<style>
    .header {
        height: 100px;
        background: var(--chernyy);
    }

    .logo {
        display: block;
        width: 100px;
        height: 100px;

        padding: 15px;
    }

    .logo img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .content {
        display: flex;
        align-items: center;
        justify-content: space-between;

        gap: 30px;
    }

    .linkBox {
    }

    .linkH {
        font-family: var(--font-family);
        font-weight: 400;
        font-size: 18px;
        color: var(--svetlo-seryy);

        transition: 300ms;
        height: 100%;
        padding: 30px 20px;

        position: relative;
    }

    .linkH:hover {
        color: var(--zheltyy);
    }

    .linkH:active {
        color: var(--oranzhevyy);
    }

    .linkH:not(:first-child)::after {
        content: "";
        position: absolute;
        top: 35%;
        height: 30px;
        width: 1px;
        left: 0px;
        background: var(--svetlyy);
        opacity: 0.5;
    }

    .butSoc {
        height: 62px;
        min-height: 62px;
        padding: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        cursor: pointer;
        background: rgba(255, 255, 255, 0.05);
        transition: 300ms all;
        filter: drop-shadow(1px 1px 5px #ffffff91);
    }

    .icon {
        width: 43px;
        height: 37px;
    }
</style>
