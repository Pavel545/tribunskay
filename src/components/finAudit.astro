---
import UniversalAnimated from "./ui/framer-motion/UniversalAnimated";
import VideoBackground from "./ui/VideoBackground.astro";
---

<VideoBackground id="finAudit" videoSrc="/video/fon2.webm">
    <div class="content">
        <UniversalAnimated
            client:load
            type="scroll"
            direction="up"
            duration={0.87}
            delay={0.3}
        >
            <h2 class="title">
                <span class="yellow"> Финансовый аудит</span>
<br>
                вашей компании
            </h2>
        </UniversalAnimated>

        <a href="/financial-audit" class="butt"> Перейти на страницу </a>
    </div>
</VideoBackground>

<style>
    .content {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .title {
        font-family: var(--second-family) !important;
        font-weight: 700;
        font-size: clamp(32px, 4vw, 75px);

        line-height: 100%;
        text-transform: uppercase;
        text-align: center;
        color: var(--belyy);

        margin-bottom: 70px;
    }
</style>
