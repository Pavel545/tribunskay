---
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";
import PopupForm from "../components/ui/FormPopup.astro";
import Preloader from "../components/Preloader.astro"; // импорт компонента

const { showPreloader = true } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
			<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon-16x16.png" />
		<link rel="icon" href="/favicon.ico" />
		
		<!-- PRELOAD ШРИФТОВ -->
		<link rel="preload" href="/font/Book Antiqua/bookantiqua_bold.ttf" as="font" type="font/ttf" crossorigin="anonymous">
		<link rel="preload" href="/font/Gilroy/Gilroy-ExtraBold.otf" as="font" type="font/otf" crossorigin="anonymous">
		<link rel="preload" href="/font/Inter/Inter-V.ttf" as="font" type="font/ttf" crossorigin="anonymous">
		
		<style>
			/* @font-face и базовые стили */
			@font-face {
				font-family: "Book Antiqua";
				src: url("/font/Book Antiqua/bookantiqua_bold.ttf") format("truetype");
				font-weight: 700;
				font-display: swap;
			}
			@font-face {
				font-family: "Gilroy";
				src: url("/font/Gilroy/Gilroy-ExtraBold.otf") format("opentype");
				font-weight: 800;
				font-display: swap;
			}
			@font-face {
				font-family: "Inter";
				src: url("/font/Inter/Inter-V.ttf") format("truetype");
				font-weight: 100 900;
				font-display: swap;
			}

			/* Стиль для контента */
			.loading-content {
				opacity: 0;
				transition: opacity 0.3s ease;
			}
			.loading-content.visible {
				opacity: 1;
			}
		</style>
	</head>
	<body>
		<div id="app-content" class="loading-content">
			<Header />
			<slot />
			<PopupForm id="popup-form" defaultTitle="Бесплатный аудит" />
			<Footer />
		</div>

		<Preloader show={showPreloader} spinnerType="spinner" duration={3000} />
	</body>
</html>